# ── LLM — generation (main response) ─────────────────────────────────────────
# Used in: pipeline.py — final answer generation
# Options: openrouter | ollama | openai
LLM_PROVIDER=openrouter
LLM_MODEL=moonshotai/kimi-k2
LLM_API_KEY=your-openrouter-key
# LLM_BASE_URL=   ← optional, overrides provider default

# ── LLM — agent (planner, grader, rewriter) ───────────────────────────────────
# Used in: planner.py, grader.py, rewriter.py
# Should be a fast, cheap model — runs multiple times per request.
# Options: openrouter | ollama | openai
AGENT_LLM_PROVIDER=openrouter
AGENT_LLM_MODEL=nousresearch/hermes-3-llama-3.1-405b:free
AGENT_LLM_API_KEY=your-openrouter-key
# AGENT_LLM_BASE_URL=   ← optional, overrides provider default
# If AGENT_LLM_API_KEY is empty, falls back to LLM_API_KEY automatically.

# ── Embedding ─────────────────────────────────────────────────────────────────
# Options: sentence_transformers | openai | openrouter
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_API_KEY=

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_PROVIDER=chromadb
VECTOR_STORE_PERSIST_DIRECTORY=./chroma_db
VECTOR_STORE_COLLECTION_NAME=documents
VECTOR_STORE_SIMILARITY_METRIC=cosine

# ── RAG ───────────────────────────────────────────────────────────────────────
TOP_K=4
MAX_TOKENS=1000
TEMPERATURE=0.0